# Local e2e test values (gitignored). Generated for deploy/integration testing.

# --- MySQL ---
MYSQL_ROOT_PASSWORD=rootpw123
MYSQL_DATABASE=agentsdast
MYSQL_USER=agentsdast
MYSQL_PASSWORD=agentpw123
MYSQL_PORT=3306

# --- MinIO ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=agentsdast
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- AgentDAST service ---
# Internal to the compose network (no host port). Other agents reach it at
# http://agentdast:8080. For the e2e test the auditor points at the mock LLM.
OPENAI_BASE_URL=http://mock:8090/v1
OPENAI_API_KEY=test-key
OPENAI_MODEL=mock-model
AI_MAX_TURNS=20
MAX_CONCURRENT_SCANS=2

# SAST table lookup: AgentDAST reads the project's swagger key, SAST report key,
# and target base URL from this table, keyed by project_id.
SAST_TABLE=sast
SAST_SWAGGER_COLUMN=result_swagger_path
SAST_REPORT_COLUMN=result_report_path
SAST_BASEURL_COLUMN=result_swagger_base_url
SAST_PROJECT_COLUMN=project_id

# DAST report output location in MinIO: <project_id>/<DAST_REPORT_DIR>/<DAST_REPORT_FILE>
DAST_REPORT_DIR=dast
DAST_REPORT_FILE=report.md
